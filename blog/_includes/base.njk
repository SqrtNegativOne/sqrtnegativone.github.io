<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title | default("the Blog") }} — Ark Malhotra</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400&family=Instrument+Serif&family=Inter:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <style>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #f5f2ed;
      --text: #1a1a1a;
      --text-secondary: #555;
    }

    [data-theme="dark"] {
      --bg: #0e0e0e;
      --text: #e8e8e8;
      --text-secondary: #aaa;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: "Inter", sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    ::selection {
      background: var(--text);
      color: var(--bg);
    }

    /* ── Viewport border frame ── */
    body::before {
      content: '';
      position: fixed;
      inset: 40px;
      border: 1px solid var(--text);
      opacity: 0.18;
      pointer-events: none;
      z-index: 9999;
      transition: opacity 0.4s ease, inset 0.4s ease;
    }

    body.border-out::before {
      opacity: 0;
      inset: 0;
    }

    /* Post pages: no border */
    body.no-border::before {
      display: none;
    }

    @media (max-width: 640px) {
      body::before { inset: 16px; }
      body.border-out::before { inset: 0; }
    }

    /* ── Blog layout: two-column with vertical divider ── */
    .blog-layout {
      display: flex;
      min-height: 100vh;
      padding: 4rem;
    }

    /* Single post: center content, no side header */
    .blog-layout.is-post {
      justify-content: center;
      padding: 3rem 2rem;
    }

    .blog-layout.is-post .blog-content {
      padding-left: 0;
      padding-top: 0;
      max-width: 640px;
      width: 100%;
      max-height: none;
      overflow-y: visible;
    }

    /* Left panel: "the BLOG" title */
    .blog-header {
      flex-shrink: 0;
      display: flex;
      align-items: flex-end;
      padding-bottom: 2rem;
      padding-right: 3rem;
    }

    .blog-title {
      font-family: "Instrument Serif", serif;
      font-weight: 400;
      font-size: clamp(3rem, 6vw, 5rem);
      line-height: 1;
      color: var(--text);
    }

    .blog-title em {
      font-style: italic;
      font-weight: 400;
    }

    .blog-title span {
      display: block;
      font-style: normal;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .blog-title .afterdark-sub {
      display: block;
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.45em;
      font-style: normal;
      text-transform: lowercase;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      margin-top: 0.15em;
    }

    /* Vertical divider */
    .blog-divider {
      flex-shrink: 0;
      width: 1px;
      background: var(--text);
      opacity: 0.18;
      align-self: stretch;
    }

    /* Right panel: content */
    .blog-content {
      flex: 1;
      padding-left: 3rem;
      padding-top: 2rem;
      overflow-y: auto;
      max-height: 100vh;
    }

    /* ── Home link ── */
    .blog-home-link {
      display: inline-block;
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.7rem;
      font-weight: 300;
      color: var(--text-secondary);
      text-decoration: none;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 2rem;
      transition: color 0.2s;
    }

    .blog-home-link:hover {
      color: var(--text);
    }

    /* ── Post list ── */
    .post-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .post-list-item a {
      text-decoration: none;
      color: var(--text);
      display: block;
      padding: 1rem 1.2rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 8px;
      transition: background 0.25s, border-color 0.25s;
    }

    [data-theme="dark"] .post-list-item a:hover {
      background: rgba(255, 255, 255, 0.04);
      border-color: rgba(255, 255, 255, 0.15);
    }

    .post-list-item a:hover {
      background: rgba(0, 0, 0, 0.03);
      border-color: rgba(0, 0, 0, 0.12);
    }

    .post-list-title {
      font-size: 1rem;
      font-weight: 600;
      margin: 0;
    }

    .post-list-date {
      font-size: 0.75rem;
      color: var(--text-secondary);
      display: block;
      margin-top: 0.25rem;
    }

    .post-list-desc {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin-top: 0.4rem;
    }

    /* ── Single post ── */
    .post-header {
      margin-bottom: 2rem;
    }

    .post-title {
      font-family: "Instrument Serif", serif;
      font-weight: 400;
      font-size: 1.8rem;
      line-height: 1.3;
    }

    .post-date {
      font-size: 0.75rem;
      color: var(--text-secondary);
      display: block;
      margin-top: 0.5rem;
    }

    .post-body {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-width: 520px;
    }

    .post-body p {
      font-size: 0.9rem;
      line-height: 1.7;
    }

    .post-body del {
      opacity: 0.5;
    }

    .post-body blockquote {
      border-left: 2px solid var(--text-secondary);
      padding-left: 1.2rem;
      margin: 0.5rem 0;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
    }

    .post-body blockquote p {
      font-style: italic;
      color: var(--text-secondary);
      font-size: 0.85rem;
    }

    .post-body strong {
      font-weight: 700;
    }

    .post-back {
      display: inline-block;
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.75rem;
      color: var(--text-secondary);
      text-decoration: none;
      margin-bottom: 1.5rem;
      transition: color 0.2s;
    }

    .post-back:hover {
      color: var(--text);
    }

    /* ── Afterdark badge ── */
    .afterdark-badge {
      display: inline-block;
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-secondary);
      border: 1px solid var(--text-secondary);
      border-radius: 3px;
      padding: 0.15rem 0.5rem;
      margin-bottom: 1.5rem;
      opacity: 0.6;
    }

    /* ── Footnotes ── */
    .footnotes {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(128, 128, 128, 0.2);
      font-size: 0.78rem;
      color: var(--text-secondary);
    }

    .footnotes ol {
      padding-left: 1.4rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .footnotes li {
      line-height: 1.6;
    }

    /* Inline footnote reference superscript */
    .footnote-ref a {
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.65rem;
      color: var(--text-secondary);
      text-decoration: none;
      padding: 0 0.15em;
      border-bottom: 1px solid var(--text-secondary);
      vertical-align: super;
      transition: color 0.2s;
    }

    .footnote-ref a:hover {
      color: var(--text);
      border-color: var(--text);
    }

    /* Back-reference arrow */
    .footnote-backref {
      font-size: 0.7rem;
      text-decoration: none;
      color: var(--text-secondary);
      margin-left: 0.3em;
      transition: color 0.2s;
    }

    .footnote-backref:hover {
      color: var(--text);
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .blog-layout {
        flex-direction: column;
        padding: 2rem 1.5rem;
      }

      .blog-header {
        padding: 0 0 1.5rem 0;
        align-items: flex-start;
      }

      .blog-title {
        font-size: 2.5rem;
      }

      .blog-divider {
        width: 100%;
        height: 1px;
        align-self: auto;
      }

      .blog-content {
        padding: 1.5rem 0 0 0;
        max-height: none;
        overflow-y: visible;
      }
    }
  </style>
</head>
{% set isPost = bodyClass == "no-border" %}
<body class="{{ bodyClass }}">
  <div class="blog-layout{% if isPost %} is-post{% endif %}">
    {% if not isPost %}
    <header class="blog-header">
      <h1 class="blog-title">
        <em>the</em>
        <span>BLOG</span>
        {% if isAfterdark %}<span class="afterdark-sub">afterdark</span>{% endif %}
      </h1>
    </header>

    <div class="blog-divider"></div>
    {% endif %}

    <div class="blog-content">
      {% if not isPost %}
      <a href="/" class="blog-home-link">&larr; Back to site</a>
      {% endif %}
      {{ content | safe }}
    </div>
  </div>

  {% if not bodyClass %}
  {# Listing pages: animate border out when clicking a post link #}
  <script>
    document.querySelectorAll('.post-list-item a').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var href = this.href;
        document.body.classList.add('border-out');
        setTimeout(function() {
          window.location.href = href;
        }, 400);
      });
    });
  </script>
  {% endif %}
</body>
</html>
